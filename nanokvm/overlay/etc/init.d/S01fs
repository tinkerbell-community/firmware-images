#!/bin/sh
# Filesystem initialization for NanoKVM BMC
#
# Partition layout on /dev/mmcblk0:
#   p1 — /boot           (vfat, factory image)
#   p2 — / rootfs        (ext4, fixed at 8192 MB)
#   p3 — /data           (exfat, occupies all remaining space)
#                        Created on first boot. Holds firmware images,
#                        ISO media, configs, and persistent BMC state.

case "$1" in
    start)
        . /etc/profile

        printf "Resizing rootfs partition (p2): "
        # Pin p2 to a deterministic 8192 MB so any leftover space at the
        # end of the device is available for the data partition. parted is
        # idempotent — this is a no-op if p2 is already the requested size.
        parted -s /dev/mmcblk0 "resizepart 2 -0" >/dev/null 2>&1
        echo "yes
        8192MB
        " | parted ---pretend-input-tty /dev/mmcblk0 "resizepart 2 8192MB" >/dev/null 2>&1
        (resize2fs /dev/mmcblk0p2 >/dev/null 2>&1) &
        echo "OK"

        printf "Mounting boot/configfs/debugfs: "
        mkdir -p /boot
        mount -t vfat /dev/mmcblk0p1 /boot 2>/dev/null
        mount -t configfs configfs /sys/kernel/config 2>/dev/null
        mount -t debugfs debugfs /sys/kernel/debug 2>/dev/null
        echo "OK"

        # Create p3 on first boot using all remaining space after p2.
        if [ ! -e /dev/mmcblk0p3 ]; then
            printf "Creating data partition (p3): "
            parted -s /dev/mmcblk0 "mkpart primary 8193MB 100%" >/dev/null 2>&1
            # Wait briefly for the kernel to expose the new partition node.
            for i in 1 2 3 4 5; do
                [ -e /dev/mmcblk0p3 ] && break
                sleep 1
            done
            mkfs.exfat /dev/mmcblk0p3 >/dev/null 2>&1
            echo "OK"
        fi

        # Mount /data and ensure BMC staging directories exist.
        if [ -e /dev/mmcblk0p3 ]; then
            printf "Mounting /data: "
            mkdir -p /data
            mount /dev/mmcblk0p3 /data 2>/dev/null
            mkdir -p /data/firmware /data/firmware/files /data/media
            echo "OK"
        fi
        ;;
    stop)
        ;;
    *)
        echo "Usage: $0 {start|stop}"
        exit 1
        ;;
esac
