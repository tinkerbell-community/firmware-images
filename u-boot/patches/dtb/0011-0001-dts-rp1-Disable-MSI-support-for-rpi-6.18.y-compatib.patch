From 3e9ad87d2a3f4d2a09fe8f9a6df4ad51fef8e95d Mon Sep 17 00:00:00 2001
From: Tinkerbell Community <tinkerbell@community.io>
Date: Wed, 14 May 2026 10:00:00 +0000
Subject: [PATCH] dts: bcm2712: Reassert pcie2 MSI domain wiring for RP1

Talos can fail probing rp1_pci with:
  error -ENOTSUPP: Failed to allocate MSI-X vectors

That failure happens when the pcie2 host does not expose a usable MSI domain
at runtime. Reassert the pcie2 MSI properties in board-level DTS files so the
final merged tree always advertises the MSI interrupt and parent domain.

This keeps RP1 on MSI/MSI-X and avoids deferred-probe cascades from a failed
rp1_pci bind.

Signed-off-by: Tinkerbell Community <tinkerbell@community.io>
---
 arch/arm64/boot/dts/broadcom/bcm2712-rpi-5-b.dts  | 3 +++
 arch/arm64/boot/dts/broadcom/bcm2712-rpi-cm5.dtsi | 3 +++
 2 files changed, 6 insertions(+)

diff --git a/arch/arm64/boot/dts/broadcom/bcm2712-rpi-5-b.dts b/arch/arm64/boot/dts/broadcom/bcm2712-rpi-5-b.dts
index 2939214..a2c3450 100644
--- a/arch/arm64/boot/dts/broadcom/bcm2712-rpi-5-b.dts
+++ b/arch/arm64/boot/dts/broadcom/bcm2712-rpi-5-b.dts
@@ -354,6 +354,9 @@
 &pcie2 {
+	interrupt-names = "pcie", "msi";
+	msi-controller;
+	msi-parent = <&mip0>;
 	status = "okay";
 };
 
diff --git a/arch/arm64/boot/dts/broadcom/bcm2712-rpi-cm5.dtsi b/arch/arm64/boot/dts/broadcom/bcm2712-rpi-cm5.dtsi
index 4eb7818..18e8157 100644
--- a/arch/arm64/boot/dts/broadcom/bcm2712-rpi-cm5.dtsi
+++ b/arch/arm64/boot/dts/broadcom/bcm2712-rpi-cm5.dtsi
@@ -312,6 +312,9 @@
 &pcie2 {
+	interrupt-names = "pcie", "msi";
+	msi-controller;
+	msi-parent = <&mip0>;
 	status = "okay";
 };
 
-- 
